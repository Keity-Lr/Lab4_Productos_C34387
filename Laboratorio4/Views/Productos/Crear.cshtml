@model Producto

<h2 class="mb-4">Agregar Producto</h2>

<form asp-action="Crear" class="card p-4 shadow-sm">

    <div class="mb-3">
        <label class="form-label">Nombre</label>
        <input asp-for="Nombre" class="form-control" />
        <span asp-validation-for="Nombre" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Precio</label>
        <input asp-for="Precio" class="form-control" />
        <span asp-validation-for="Precio" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Categoría</label>
        <select asp-for="Categoria" class="form-select">
            <option>Electrónica</option>
            <option>Ropa</option>
            <option>Hogar</option>
            <option>Alimentos</option>
        </select>
        <span asp-validation-for="Categoria" class="text-danger"></span>
    </div>

    <div class="d-flex gap-2 mt-3">
        <button type="submit" class="btn px-4 py-2"
                style="background-color:#4a90e2; color:white; border-radius:6px;">
            Guardar
        </button>

        <a asp-action="Index" class="btn px-4 py-2"
               style="background-color:#6c757d; color:white; border-radius:6px;">
            Cancelar
        </a>
    </div>

</form>